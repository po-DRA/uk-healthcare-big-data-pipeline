{
  "name": "UK Healthcare Big Data Pipeline",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/astral-sh/uv/devcontainer-feature:1": {}
  },
  "postCreateCommand": "uv sync --all-groups && uv run pre-commit install",
  "forwardPorts": [2718, 4200, 8585],
  "portsAttributes": {
    "2718": {
      "label": "Marimo notebooks",
      "onAutoForward": "openBrowser"
    },
    "4200": {
      "label": "Prefect UI",
      "onAutoForward": "notify"
    },
    "8585": {
      "label": "OpenMetadata UI (optional)",
      "onAutoForward": "ignore"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "eamodio.gitlens",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}
